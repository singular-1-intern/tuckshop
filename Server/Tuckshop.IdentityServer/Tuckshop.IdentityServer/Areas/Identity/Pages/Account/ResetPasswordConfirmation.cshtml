@page
@model ResetPasswordConfirmationModel

@{
  ViewData["Title"] = "Reset Password";
  ViewData["AuthPageTitle"] = "Password reset complete";
  ViewData["AuthPageSubtitle"] = "You can now sign in with your new password.";
  ViewData["AuthVisualTitle"] = "";
  ViewData["AuthVisualSubtitle"] = "";
}

<div class="auth-page__outcome-card auth-page__outcome-card--success">
  <div class="auth-page__outcome-icon" aria-hidden="true">
    <span class="material-symbols-rounded">lock_reset</span>
  </div>
  <div class="auth-page__outcome-body">
    <p class="auth-page__outcome-title">Your password has been reset.</p>
    <p class="auth-page__outcome-text">You can now sign in using your updated credentials.</p>
  </div>
</div>
<div class="text-center mt-3">
  <span class="material-symbols-rounded auth-page__success-icon mt-4 mb-2" aria-hidden="true">check_circle</span>
</div>
<div class="row auth-page__cta-row">
  <div class="col-md-12 text-center p-0">
    <button id="to-login-button" class="btn btn-primary w-100">Back to Login</button>
  </div>
</div>

@section Scripts {
  <partial name="_HelperScripts" />
  <partial name="_ValidationScriptsPartial" />
}
