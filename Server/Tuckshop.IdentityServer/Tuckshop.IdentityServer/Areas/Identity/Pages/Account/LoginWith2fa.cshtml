@page
@model LoginWith2faModel

@{
  ViewData["Title"] = "Login 2FA";
  ViewData["AuthPageTitle"] = "Two-factor authentication";
  ViewData["AuthPageSubtitle"] = "Enter your authenticator code to continue.";
  ViewData["AuthVisualTitle"] = "";
  ViewData["AuthVisualSubtitle"] = "";
}

<form method="post" asp-route-returnUrl="@Model.ReturnUrl" class="auth-page__form-stack">
  <div class="auth-page__status-info auth-page__info-block mb-3">
    <p class="mb-0">Your login is protected with an authenticator app. Enter your authenticator code below.</p>
  </div>

  <input asp-for="RememberMe" type="hidden" />

  <div asp-validation-summary="ModelOnly" class="auth-page__status-error" role="alert"></div>
  <div class="form-group mb-3 auth-page__field">
    <label asp-for="Input.TwoFactorCode"></label>
    <input asp-for="Input.TwoFactorCode" class="form-control" autocomplete="off" autofocus />
    <span asp-validation-for="Input.TwoFactorCode" class="invalid-feedback"></span>
  </div>

  <div class="row text-center auth-page__cta-row">
    <div class="col-md-12 mb-2">
      <button type="submit" class="w-100 btn btn-primary">Login</button>
    </div>
  </div>
</form>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
}