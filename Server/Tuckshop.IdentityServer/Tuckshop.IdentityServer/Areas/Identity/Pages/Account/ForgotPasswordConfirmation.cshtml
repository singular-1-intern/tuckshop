@page
@model ForgotPasswordConfirmation

@{
  ViewData["Title"] = "Forgot Password";
  ViewData["AuthPageTitle"] = "Password reset email sent";
  ViewData["AuthPageSubtitle"] = "Check your inbox for the reset link.";
  ViewData["AuthVisualTitle"] = "";
  ViewData["AuthVisualSubtitle"] = "";
}

<div class="auth-page__outcome-card auth-page__outcome-card--success">
  <div class="auth-page__outcome-icon" aria-hidden="true">
    <span class="material-symbols-rounded">mail</span>
  </div>
  <div class="auth-page__outcome-body">
    <p class="auth-page__outcome-title">Password reset email sent</p>
    <p class="auth-page__outcome-text">A password reset email has been sent to you, please check your in-box to reset your password.</p>
    <p class="auth-page__outcome-meta">The email link will expire in @Model.LinkExpiryDuration.</p>
  </div>
</div>
<div class="text-center mt-3">
  <span class="material-symbols-rounded auth-page__success-icon mt-5 mb-2" aria-hidden="true">check_circle</span>
</div>
<div class="text-center mt-5">
  <button id="to-login-button" class="btn btn-primary w-100">Back to Login</button>
</div>

@section Scripts {
  <partial name="_HelperScripts" />
}

