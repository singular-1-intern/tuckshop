@page
@model ResetPasswordModel

@{
  ViewData["Title"] = "Reset Password";
  ViewData["AuthPageTitle"] = "Reset password";
  ViewData["AuthPageSubtitle"] = "Choose a new password to continue securely.";
  ViewData["AuthVisualTitle"] = "";
  ViewData["AuthVisualSubtitle"] = "";
}

<form method="post" class="auth-page__form-stack">
  <div asp-validation-summary="ModelOnly" class="auth-page__status-error" role="alert"></div>
  <input asp-for="Input.Code" type="hidden" />
  <div class="form-group mb-3 auth-page__field">
    <label asp-for="Input.Email"></label>
    <input asp-for="Input.Email" class="form-control" />
    <span asp-validation-for="Input.Email" class="invalid-feedback"></span>
  </div>
  <div class="form-group mb-3 auth-page__field">
    <label asp-for="Password"></label>
    <input asp-for="Password" class="form-control" />
    <span asp-validation-for="Password" class="invalid-feedback"></span>
  </div>
  <div class="form-group mb-3 auth-page__field">
    <label asp-for="ConfirmPassword"></label>
    <input asp-for="ConfirmPassword" class="form-control" />
    <span asp-validation-for="ConfirmPassword" class="invalid-feedback"></span>
  </div>
  <div class="auth-page__cta-row">
    <button type="submit" class="btn btn-primary w-100">Reset Password</button>
  </div>
  <div class="text-center mt-2">
    <a asp-page="./Login" class="auth-page__action-link">Back to Login</a>
  </div>
</form>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
}
