@page
@model ForgotPasswordModel

@{
  ViewData["Title"] = "Forgot Password";
  ViewData["AuthPageTitle"] = "Forgot password";
  ViewData["AuthPageSubtitle"] = "Enter your email and we’ll send a secure reset link.";
  ViewData["AuthVisualTitle"] = "";
  ViewData["AuthVisualSubtitle"] = "";
}

<form method="post" class="auth-page__form-stack">
  <div asp-validation-summary="ModelOnly" class="auth-page__status-error" role="alert"></div>
  <div class="form-group mt-3 mb-3 auth-page__field">
    <label asp-for="Input.Email"></label>
    <input asp-for="Input.Email" class="form-control" />
    <span asp-validation-for="Input.Email" class="invalid-feedback"></span>
  </div>
  <div class="row text-center mt-4 auth-page__cta-row">
    <div class="col-12">
      <button type="submit" class="btn btn-primary w-100">Submit</button>
    </div>
    <div class="col-12 mt-2 text-center">
      <a asp-page="./Login" class="auth-page__action-link">Back to Login</a>
    </div>
  </div>
</form>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
}
