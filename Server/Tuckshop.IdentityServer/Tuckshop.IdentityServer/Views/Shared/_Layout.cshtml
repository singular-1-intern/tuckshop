@using Microsoft.AspNetCore.Html
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"] - Tuckshop</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:FILL@0..1" />
  <link rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous" />

  <environment include="Development">
    <link rel="stylesheet" href="~/css/scss/App.css" asp-append-version="true" />
  </environment>
  <environment exclude="Development">
    <link rel="stylesheet" href="~/css/scss/App.min.css" asp-append-version="true" />
  </environment>
</head>
@{
  var authLogoPath = ViewData["AuthLogoPath"]?.ToString() ?? Url.Content("~/images/logo_dark.svg");
  var authTitle = ViewData["AuthPageTitle"]?.ToString() ?? ViewData["Title"]?.ToString();
  var authSubtitle = ViewData["AuthPageSubtitle"]?.ToString();
  var authVisualTitle = ViewData["AuthVisualTitle"]?.ToString();
  var authVisualSubtitle = ViewData["AuthVisualSubtitle"]?.ToString();
  var authSupportHtml = ViewData["AuthSupportHtml"] as IHtmlContent;
}
<body class="auth-layout">
  <partial name="_CookieConsentPartial" />

  <div class="site-container">
    <div id="site-body" class="container body-content">
      <div class="row justify-content-center">
        <div class="col-xl-10 col-xxl-9">
          <div class="auth-page">
            <section class="auth-page__shell i-box">
              <aside class="auth-page__visual" aria-hidden="true">
                <div class="auth-page__visual-content">
                  <p class="auth-page__brand-display">
                    <span class="auth-page__brand-singular">Neo</span><span class="auth-page__brand-one">Template</span>
                  </p>
                  @if (!string.IsNullOrWhiteSpace(authVisualTitle))
                  {
                    <p class="auth-page__visual-tagline">@authVisualTitle</p>
                  }
                  else
                  {
                    <p class="auth-page__visual-tagline">Your platform. Powered by <span class="auth-page__brand-one">Singular</span></p>
                  }
                  @if (!string.IsNullOrWhiteSpace(authVisualSubtitle))
                  {
                    <p class="auth-page__visual-tagline auth-page__visual-tagline--sub">@authVisualSubtitle</p>
                  }
                </div>
              </aside>

              <div class="auth-page__form">
                <header class="auth-page__header">
                  <img src="@authLogoPath" class="logo-style auth-page__logo" alt="Tuckshop" />
                  @if (!string.IsNullOrWhiteSpace(authTitle))
                  {
                    <h1 class="auth-page__title">@authTitle</h1>
                  }
                  @if (!string.IsNullOrWhiteSpace(authSubtitle))
                  {
                    <p class="auth-page__subtitle">@authSubtitle</p>
                  }
                </header>

                <div class="auth-page__content">
                  @RenderBody()
                </div>

                @if (IsSectionDefined("AuthSupport") || authSupportHtml != null)
                {
                  <div class="auth-page__support">
                    @if (IsSectionDefined("AuthSupport"))
                    {
                      @RenderSection("AuthSupport", required: false)
                    }
                    else
                    {
                      @authSupportHtml
                    }
                  </div>
                }
              </div>
            </section>
          </div>
        </div>
      </div>
    </div>
  </div>

  <environment include="Development">
    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
  </environment>
  <environment exclude="Development">
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
    <script src="~/js/site.min.js" asp-append-version="true"></script>
  </environment>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
          integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
          crossorigin="anonymous"></script>

  @RenderSection("Scripts", required: false)
</body>
</html>
