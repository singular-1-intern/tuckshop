{
  // --------------------------------------------------------------------------
  // Logging
  // --------------------------------------------------------------------------
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug"
    },
    "WriteTo": {
      "Console": {
        "Name": "Console",
        "Args": {
          "restrictedToMinimumLevel": "Debug"
        }
      },
      "MSSqlServer": {
        "Name": "MSSqlServer",
        "Args": {
          "restrictedToMinimumLevel": "Information"
        }
      }
    }
  }
}
