{
  // --------------------------------------------------------------------------
  // Application Configuration
  // --------------------------------------------------------------------------
  "ConnectionStrings": {
    "Main": "Server=(local); Database=Tuckshop.IdentityServer; Trusted_Connection=True; Encrypt=True; TrustServerCertificate=True; Connection Timeout=30; Column Encryption Setting=Enabled; MultipleActiveResultSets=True; Persist Security Info=True;"
  },
  "Kestrel": {
    "Certificates": {
      "Default": {
        "Path": "Certificates/neo-localhost.pfx",
        "Password": "P@ssw0rd"
      }
    },
    "EndPoints": {
      // When changing the port, also update it in launchSettings.json
      "Https": {
        "Certificate": "Default",
        "Url": "https://*:5000"
      }
    }
  },
  "Routing": {
    "ForwardedHeaders": {
      "Headers": "None"
    },
    "PathBase": "",
    "AppFolder": ""
  },
  "AuthenticationServer": {
    "IssuerUri": "https://localhost:5000",
    "TokenEncryptionCredential": "", // make this empty for Dev so that it uses the EncryptionKey
    "TokenEncryptionKey": "ThisIsAShared32ChrDevelopmentKey", // if you change this you will need to also change your Domain project(s)
    // TODO: This needs to be updated to the client's preferred state in their corresponding App YAML config file.
    "DisableTokenEncryption": true
  },
  "AuthenticationClients:0:RedirectUris": [
    "https://localhost:3000/OidcLoginRedirect",
    "https://localhost:3000/OidcSilentLoginRedirect"
  ],
  "AuthenticationClients:1:Secret": "secret",
  "AuthenticationClients:1:RedirectUris": [ "https://localhost:5001/oauth2-redirect.html" ],
  "SeedUsers": {
    "TestUserPassword": "P@ssw0rd",
    "SuperUserPassword": "P@ssw0rd"
  },
  "Passwords": {
    "RequiredLength": 8
  },

  // --------------------------------------------------------------------------
  // Local Services
  // --------------------------------------------------------------------------
  "Authentication": {
    "AuthenticationAuthorityUrl": "https://localhost:5000",
    "AuthorizationUrl": "https://localhost:5000/connect/authorize",
    "TokenUrl": "https://localhost:5000/connect/token"
  },
  "Authorisation": {
    "EndPoint": "https://localhost:5001/authorisation/api/",
    "ServiceBusOptions": {
      // TODO: This needs to be updated to the client's provisioned Service Bus, in their App YAML config file.
      "FullyQualifiedNamespace": "singular-dev-service-bus.servicebus.windows.net"
    }
  },
  "NotificationServer": {
    "EndPoint": "https://localhost:5001/api/"
  },
  "Urls": {
    "Dashboard": "https://localhost:3000/"
  },

  // --------------------------------------------------------------------------
  // External Services
  // --------------------------------------------------------------------------
  "KeyVaults:0:Enabled": false, // Disable KeyVault 'Main'
  // "KeyVaults:0:Name": "", // If a dev Key Vault is provisioned, uncomment this and set it to the name of the Key Vault
  "AlwaysEncrypted": {
    "Enabled": false,
    "DatabaseKeyPrefix": "Tuckshop-dev" // Should follow the format: [projectPrefix]-[environment] (E.g. nsmp-dev)
  },
  "EmailSender": {
    "Provider": "SMTP",
    "Host": "mail.singular.co.za",
    "EnableSSL": false,
    "UserName": "developer@singular.co.za",
    "Password": ""
  },

  // --------------------------------------------------------------------------
  // Logging
  // --------------------------------------------------------------------------
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "System": "Information",
      "Microsoft": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        // Note: These namespaces have been overridden to make standard app logging less noisy.If you need to debug something that's
        //       being suppressed by these overrides, such as the SQL statements being generated by EF Core, you can drop the log level
        //       by overriding these base settings in the appsettings.Development.json file.
        "System": "Debug",
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Migrations": "Information",

        "Microsoft.AspNetCore.Cors": "Warning",
        "Microsoft.AspNetCore.Mvc.Infrastructure": "Warning",
        "Microsoft.AspNetCore.Routing.Matching": "Information",

        "Quartz": "Warning",
        "Neo": "Information"
      }
    },
    "WriteTo": {
      "Console": {
        "Name": "Console",
        "Args": {
          "restrictedToMinimumLevel": "Debug"
        }
      },
      "MSSqlServer": {
        "Name": "MSSqlServer",
        "Args": {
          "restrictedToMinimumLevel": "Information"
        }
      }
    }
  }
}