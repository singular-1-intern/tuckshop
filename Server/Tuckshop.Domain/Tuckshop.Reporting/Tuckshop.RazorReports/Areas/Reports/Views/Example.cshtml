@using Neo.Reporting.Pdf;
@using Tuckshop.Core.Models.Files;
@using Neo.Reporting;
@using Tuckshop.RazorReports;
@using Tuckshop.Reporting.Reports.Example;

@inherits ReportView<ExampleCriteria, List<ExampleReportLookup>>

@inject ReportStyleService styleService
@inject IHtmlScriptProvider scriptProvider

@styleService.RenderReportingStyles(Options.Embedded)

<link rel="stylesheet" href="@styleService.AbsolutePath(this.Url, Options.Embedded, "css/fonts.css")">

@Html.Raw(scriptProvider.EnsureFontsLoaded(Options.Embedded))

@{
  // Note: this is for demo purposes, never create a file descriptor like this.
  var neoLogo = new FileDescriptor() 
  { 
    FileName = "neo.png", 
    FileData = Convert.FromBase64String("") 
  };
}

<style type="text/css">
  .report-page-header {
      border-bottom: 1px solid #000;
  }
</style>

<div class="report-view example-report">

  <page-header>
    <flex-layout>
      <div>
        <h1>Tuckshop</h1>
        <h2>Example Report</h2>
      </div>
      <div>
        <inline-image file="@neoLogo" style="max-width: 50px" />
      </div>
    </flex-layout>
    
  </page-header>

  <div class="report-header">
    <p class="mt-0">
      Search string: <strong>@Criteria.SearchString</strong>
    </p>
  </div>

  <table class="grid">
    <thead>
      <tr>
        <th>First Name</th>
        <th>Last Name</th>
        <date-cell>Join Date</date-cell>
        <number-cell>Salary</number-cell>
      </tr>
    </thead>
    <tbody>
      @foreach (var user in Data)
      {
        <tr>
          <td>@user.FirstName</td>
          <td>@user.LastName</td>
          <date-cell value="@user.JoinDate" />
          <number-cell value="@user.Salary" />
        </tr>
      }
    </tbody>
  </table>

  <new-page>
    This should print on a new page.
  </new-page>

  <page-footer>
    <flex-layout>
      <div>Created on @Options.LocalDateTime.ToString("dd MMM yyyy") at @Options.LocalDateTime.ToString("HH:mm")</div>
      <div>Page {page} of {total-pages}</div>
    </flex-layout>
  </page-footer>
</div>