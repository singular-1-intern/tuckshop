<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>14.0</LangVersion>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Company>Singular Systems (Pty) Ltd</Company>
    <Authors>$(Company)</Authors>
    <Copyright>$([System.DateTime]::Now.ToString(yyyy)) by $(Company)</Copyright>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <RunAnalyzersDuringLiveAnalysis>true</RunAnalyzersDuringLiveAnalysis>
    <RunAnalyzersDuringBuild>true</RunAnalyzersDuringBuild>
    <EnableNETAnalyzers>true</EnableNETAnalyzers>
    <AnalysisLevel>latest</AnalysisLevel>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <AspNetCoreHostingModel>InProcess</AspNetCoreHostingModel>
    <UserSecretsId>Tuckshop.Core.Api</UserSecretsId>
    <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
    <DockerfileContext>.</DockerfileContext>
    <DockerfileFile>..\Dockerfile</DockerfileFile>
    <DockerfileFastModeStage>debug</DockerfileFastModeStage>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Certificates\neo-localhost.pfx" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Certificates\neo-localhost.pfx" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.VisualStudio.Azure.Containers.Tools.Targets" />
    <PackageReference Include="Neo.Azure.KeyVault" />
    <PackageReference Include="Neo.Files" />
    <PackageReference Include="Neo.Identity.Api.OpenIddict" />
    <PackageReference Include="Neo.Identity.Clients.OpenIddict" />
    <PackageReference Include="Neo.Jobs" />
    <PackageReference Include="Neo.Model.App" />
    <PackageReference Include="Neo.Model.Serilog" />
    <PackageReference Include="Neo.Model.Swagger" />
    <PackageReference Include="Serilog.AspNetCore" />
    <PackageReference Include="Serilog.Sinks.MSSqlServer" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Tuckshop.IdentityServer\Tuckshop.IdentityServer.Clients\Tuckshop.IdentityServer.Clients.csproj" />
    <ProjectReference Include="..\Tuckshop.AuthorisationServer\Tuckshop.AuthorisationServer.Api\Tuckshop.AuthorisationServer.Api.csproj" />
    <ProjectReference Include="..\Tuckshop.Core.App\Tuckshop.Core.App.csproj" />
    <ProjectReference Include="..\Tuckshop.Core.Models.Migrations\Tuckshop.Core.Models.Migrations.csproj" />
    <ProjectReference Include="..\Tuckshop.Notifications\Tuckshop.Notifications.App\Tuckshop.Notifications.App.csproj" />
    <ProjectReference Include="..\Tuckshop.Reporting\Tuckshop.Reporting.App\Tuckshop.Reporting.App.csproj" />
  </ItemGroup>

</Project>