{
  // --------------------------------------------------------------------------
  // Neo Modular App AppSettings
  // --------------------------------------------------------------------------

  // IMPORTANT
  //   The appsettings.json file should be used for 'sensible defaults' to use when the application is deployed. (I.e. General settings for 'Staging' and 'Production' scenarios)
  //   Settings specifically for local development should be added to appsettings.Development.json.

  // The following properties must be set in your deployment configuration:
  //  - ConnectionStrings.Main                        (Set the SQL Server name, database name with project and environment prefixes)
  //  - ConnectionStrings.Notifications               (Set the SQL Server name, database name with project and environment prefixes)
  //  - ConnectionStrings.Reporting                   (Set the SQL Server name, database name with project and environment prefixes)
  //  - NotificationSettings.Sender.EmailAddress      (If you want to set a reply address)
  //  - NotificationSettings.EmailSender.FromAddress  (If you want to set a reply address)
  //  - Authentication.AuthenticationAuthorityUrl
  //  - Authentication.AuthorizationUrl
  //  - Authentication.TokenUrl
  //  - Authorisation.AuthorisationServiceUrl          (If not deploying into K8s)
  //  - KeyVaults[0].Name

  // --------------------------------------------------------------------------
  // Application Configuration
  // --------------------------------------------------------------------------
  "App": {
    "Title": "Tuckshop WebApi",
    "Version": "1.0.0",
    "ApiVersion": "1.0"
  },
  "ConnectionStrings": {
    // Set this value in your deployment config yaml files. (E.g: Server=scstgvmsql01;Initial Catalog=NS.QA.Domain;User ID={KeyVault:SqlAppUsername};Password={KeyVault:SqlAppPassword};Encrypt=True;TrustServerCertificate=True;Connection Timeout=30;Column Encryption Setting=Enabled;MultipleActiveResultSets=True;Persist Security Info=True;)
    "Main": "",
    // Set this value in your deployment config yaml files. (E.g: Server=scstgvmsql01;Initial Catalog=NS.QA.Notifications;User ID={KeyVault:SqlAppUsername};Password={KeyVault:SqlAppPassword};Encrypt=True;TrustServerCertificate=True;Connection Timeout=30;Column Encryption Setting=Enabled;MultipleActiveResultSets=True;Persist Security Info=True;)
    "Notifications": "",
    // Set this value in your deployment config yaml files. (E.g: Server=scstgvmsql01;Initial Catalog=NS.QA.Reporting;User ID={KeyVault:SqlAppUsername};Password={KeyVault:SqlAppPassword};Encrypt=True;TrustServerCertificate=True;Connection Timeout=30;Column Encryption Setting=Enabled;MultipleActiveResultSets=True;Persist Security Info=True;)
    "Reporting": "",
    // Set this value in your deployment config yaml files. (E.g: Server=scstgvmsql01;Initial Catalog=NS.QA.Authorisation;User ID={KeyVault:SqlAppUsername};Password={KeyVault:SqlAppPassword};Encrypt=True;TrustServerCertificate=True;Connection Timeout=30;Column Encryption Setting=Enabled;MultipleActiveResultSets=True;Persist Security Info=True;)
    "Authorisation": ""
  },
  "Routing": {
    "ForwardedHeaders": {
      "Headers": "XForwardedFor,XForwardedProto,XForwardedHost"
    },
    "PathBase": "/domain",
    "AppFolder": "",
    // The {scheme}://{host} of the domain api when making requests within the cluster.
    "RootInternal": "http://domain"
  },
  "AllowedHosts": "*",
  "ApiResource": {
    "ResourceName": "Tuckshop.Domain"
  },
  "NotificationSettings": {
    "Sender": {
      "EmailAddress": "systems-mailer@singular.co.za",
      "DisplayName": ""
    },
    "EmailSender": {
      "Provider": "SendGrid",
      "SendGridApiKey": "...",
      "FromAddress": "systems-mailer@singular.co.za",
      "UseSandbox": false
    }
  },
  "ReportingService": {},
  "Swagger": {
    "Enabled": true,
    "RequireAuthorisationByDefault": true
  },

  // --------------------------------------------------------------------------
  // Local Services
  // --------------------------------------------------------------------------
  "Authentication": {
    // Set this value in your deployment config yaml files. (E.g: https://sample.domain.com/identity-server)
    "AuthenticationAuthorityUrl": "",
    // Set this value in your deployment config yaml files. (E.g: https://sample.domain.com/identity-server/connect/authorize)
    "AuthorizationUrl": "",
    // Set this value in your deployment config yaml files. (E.g: https://sample.domain.com/identity-server/connect/token)
    "TokenUrl": "",
    "TokenEncryptionCredential": "{KeyVault:AuthenticationServer:TokenEncryptionCredential}",
    "ClientId": "Tuckshop.DomainServices",
    "ClientSecret": "{KeyVault:ApiClientSecrets:Domain}",
    "Scope": "Authorisation IdentityServerApi"
  },
  "AuthorisationServer": {
    "Code": "Tuckshop",
    "Name": "Tuckshop",
    "Publication": {
      // TODO: This needs to be updated to the client's provisioned Service Bus, in their App YAML config file.
      "FullyQualifiedNamespace": "singular-dev-service-bus.servicebus.windows.net"
    },
    "Enrolment": {
      // Users with this user name will automatically become administrators.
      "Administrators": [ "alice@test.com", "bob@test.com" ]
    }
  },
  "IdentityService": {
    "EndPointUrl": "http://identity-server/api/"
  },

  // --------------------------------------------------------------------------
  // External Services
  // --------------------------------------------------------------------------
  "AzureBlobFileStores": [
    {
      "Key": "Private",
      "DefaultContainerName": "Documents",
      "Connection": {
        // Set this value in your deployment config yaml files. (E.g: nsmpdevstdocuments)
        "StorageAccountName": "..."
      }
    }
  ],
  "ServiceBus": {
    // TODO: This needs to be updated to the client's provisioned Service Bus, in their App YAML config file.
    "FullyQualifiedNamespace": ""
  },
  "KeyVaults": [
    {
      "Key": "Main",
      // Set this value in your deployment config yaml files. (E.g: ns-qa-kv-main)
      "Name": "n/a",
      "AuthenticationMethod": "DefaultCredential",
      "Enabled": true,
      "AddAsConfigProvider": true,
      "InjectSecrets": true
    }
  ],
  "AlwaysEncrypted": {
    "Enabled": false,
    "KeyStoreProviderName": "AZURE_KEY_VAULT",
    // Set this value in your deployment config yaml files. (E.g: ns-qa)
    "DatabaseKeyPrefix": "", // Should follow the format: [projectPrefix]-[environment] (E.g. nsmp-dev)
    "EnclaveEnabled": false,

    // Default constraints are not allowed on encrypted columns. When enabled, this setting will cause the constraints to be silently dropped
    // during encrypted column migrations. If disabled, an exception will be thrown at startup if default constraints are found on columns that need to be encrypted.
    "DropDefaultConstraints": true
  },

  // --------------------------------------------------------------------------
  // Logging
  // --------------------------------------------------------------------------
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    },
    "ExceptionTrimming": { "Mode": "Aggressive" },
    "Cleanup": {
      "Schedule": "0 0 2 1/1 * ? *", // 2am every day
      "DefaultDays": 30,
      "Levels": [
        {
          "Level": "Fatal",
          "Days": 180
        },
        {
          "Level": "Error",
          "Days": 180
        },
        {
          "Level": "Warning",
          "Days": 60
        }
      ]
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.MSSqlServer", "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        // Note: These namespaces have been overridden to make standard app logging less noisy.If you need to debug something that's
        //       being suppressed by these overrides, such as the SQL statements being generated by EF Core, you can drop the log level
        //       by overriding these base settings in the appsettings.Development.json file.
        "System": "Warning",
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Migrations": "Information",
        "OpenIddict": "Warning"
      }
    },
    "WriteTo": {
      "Console": {
        "Name": "Console",
        "Args": {
          "restrictedToMinimumLevel": "Information",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      "MSSqlServer": {
        "Name": "MSSqlServer",
        "Args": {
          "restrictedToMinimumLevel": "Warning",
          "connectionString": "Main",
          "sinkOptionsSection": {
            "tableName": "Logs",
            "autoCreateSqlDatabase": true,
            "autoCreateSqlTable": true
          },
          "columnOptionsSection": {
            "additionalColumns": [
              {
                "ColumnName": "Source",
                "PropertyName": "SourceContext",
                "DataType": "varchar",
                "DataLength": 200
              }
            ],
            "removeStandardColumns": [ "MessageTemplate", "Properties" ],
            "logEvent": {
              "excludeAdditionalProperties": true,
              "excludeStandardColumns": true
            }
          }
        }
      }
    }
  },
  // Logging Middleware
  //   These can be used to enable additional logging around authentication, requests/responses and multi-tenancy.
  //   NOTE: Leaving these enabled on a live environment is not recommended, as they add a lot of noise to the logs, and may also impact performance.
  "Middleware": {
    "AuthenticationInfoLogging": {
      "Enabled": false
    },
    "RequestResponseLogging": {
      "Enabled": false
    },
    "MultiTenancyInfoLogging": {
      "Enabled": false
    }
  },
  "IronPdf.LicenseKey": "{KeyVault:IronPdfLicenseKey}"
}