{
  // --------------------------------------------------------------------------
  // Application Configuration
  // --------------------------------------------------------------------------
  "ConnectionStrings": {
    "Main": "Server=(local); Database=Tuckshop.Domain; Trusted_Connection=True; Encrypt=True; TrustServerCertificate=True; Connection Timeout=30; Column Encryption Setting=Enabled; MultipleActiveResultSets=True; Persist Security Info=True;",
    "Notifications": "Server=(local); Database=Tuckshop.Notifications; Trusted_Connection=True; Encrypt=True; TrustServerCertificate=True; Connection Timeout=30; Column Encryption Setting=Enabled; MultipleActiveResultSets=True; Persist Security Info=True;",
    "Reporting": "Server=(local); Database=Tuckshop.Reporting; Trusted_Connection=True; Encrypt=True; TrustServerCertificate=True; Connection Timeout=30; Column Encryption Setting=Enabled; MultipleActiveResultSets=True; Persist Security Info=True;",
    "Authorisation": "Server=(local); Database=Tuckshop.Authorisation; Trusted_Connection=True; Encrypt=True; TrustServerCertificate=True; Connection Timeout=30; Column Encryption Setting=Enabled; MultipleActiveResultSets=True; Persist Security Info=True;"
  },
  "Kestrel": {
    "Certificates": {
      "Default": {
        "Path": "Certificates/neo-localhost.pfx",
        "Password": "P@ssw0rd"
      }
    },
    "EndPoints": {
      // When changing the port, also update it in launchSettings.json
      "Https": {
        "Certificate": "Default",
        "Url": "https://localhost:5001"
      }
    }
  },
  "Routing": {
    "ForwardedHeaders": {
      "Headers": "None"
    },
    "PathBase": "",
    "AppFolder": "",
    "RootInternal": "https://localhost:5001"
  },
  "NotificationSettings": {
    "EmailOverride": {
      // Replace "Default" in your user secrets file to use a different delivery address override. (E.g. Your own email address)
      "Default": "mail-testing@singular.co.za"
    },
    // TODO: Either configure a local development Key Vault containing a SendGrid API Key,
    //       or override "SendGridApiKey" in your user secrets file.
    "EmailSender": {
      "Provider": "SendGrid",
      "SendGridApiKey": "...",
      "FromAddress": "systems-mailer@singular.co.za",
      "UseSandbox": false
    }
  },

  // --------------------------------------------------------------------------
  // Local Services
  // --------------------------------------------------------------------------
  "Authentication": {
    "AuthenticationAuthorityUrl": "https://localhost:5000",
    "AuthorizationUrl": "https://localhost:5000/connect/authorize",
    "TokenUrl": "https://localhost:5000/connect/token",
    "TokenEncryptionCredential": "", // make this empty for Dev so that it uses the EncryptionKey
    "TokenEncryptionKey": "ThisIsAShared32ChrDevelopmentKey", // if you change this you will need to also change your Identity project
    "ClientSecret": "",
    // TODO: This needs to be updated to the client's preferred state in their corresponding App YAML config file.
    "DisableTokenEncryption": true
  },
  "AuthorisationServer": {
    "Publication": {
      "FullyQualifiedNamespace": "singular-dev-service-bus.servicebus.windows.net"
    }
  },
  "IdentityService": {
    "EndPointUrl": "https://localhost:5000/api/"
  },

  // --------------------------------------------------------------------------
  // External Services
  // --------------------------------------------------------------------------
  // TODO: If you have a local development (ldev) environment provisioned, uncomment this section and set 'StorageAccountName' to the name of the storage account.
  // "AzureBlobFileStores": [
  //   {
  //     "Connection": {
  //       "StorageAccountName": "..."
  //     }
  //   }
  // ],
  "ServiceBus": {
    // TODO: This needs to be updated to the client's provisioned Service Bus, in their App YAML config file.
    "FullyQualifiedNamespace": "singular-dev-service-bus.servicebus.windows.net"
  },
  "KeyVaults": [
    {
      "Key": "Main",
      "Name": "n/a", // If a dev Key Vault is provisioned, set this to the name of the Key Vault and enable it.
      "AuthenticationMethod": "DefaultCredential",
      "Enabled": false,
      "AddAsConfigProvider": true,
      "InjectSecrets": true
    },
    {
      "Key": "Dev",
      "Name": "sing-we-dev-kv-apps",
      "AuthenticationMethod": "DefaultCredential",
      "Enabled": true,
      "AddAsConfigProvider": true,
      "InjectSecrets": true
    }
  ],
  "AlwaysEncrypted": {
    "DatabaseKeyPrefix": "Tuckshop-dev" // Should follow the format: [projectPrefix]-[environment] (E.g. nsmp-dev)
  },

  // --------------------------------------------------------------------------
  // Logging
  // --------------------------------------------------------------------------
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "System": "Information",
      "Microsoft": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        // Note: These namespaces have been overridden to make standard app logging less noisy.If you need to debug something that's
        //       being suppressed by these overrides, such as the SQL statements being generated by EF Core, you can drop the log level
        //       by overriding these base settings in the appsettings.Development.json file.
        "System": "Debug",
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information",
        "Microsoft.EntityFrameworkCore.Migrations": "Information",
        "Microsoft.AspNetCore.Cors": "Warning",
        "Microsoft.AspNetCore.Mvc.Infrastructure": "Warning",
        "Microsoft.AspNetCore.Routing.Matching": "Information",

        "Quartz": "Warning",
        "Neo": "Information"
      }
    },
    "WriteTo": {
      "Console": {
        "Name": "Console",
        "Args": {
          "restrictedToMinimumLevel": "Debug",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
          // "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}^Source: {SourceContext}{NewLine}{Exception}" // Use this version if you want see the source context
        }
      },
      "MSSqlServer": {
        "Name": "MSSqlServer",
        "Args": {
          "restrictedToMinimumLevel": "Information"
        }
      }
    }
  }
}
